# Groq API
GROQ_API_KEY=your_groq_api_key_here

# MCP Configuration
MCP_CORE_CWD=../../mcp-servers/core
MCP_FILESYSTEM_ROOT=
MCP_GIT_REPO=

# Agent Configuration
AGENT_MODEL_NAME=llama-3.3-70b-versatile
AGENT_PHASE1_MIN_TOOLS=2
AGENT_PHASE1_CONFIDENCE_THRESHOLD=0.7
AGENT_MAX_ROUNDS=10
AGENT_PHASE1_MAX_ROUNDS=5
OLLAMA_BASE_URL=http://localhost:11434

# Server Toggles (set to 'false' to disable)
AGENT_SEARCH_SERVER_ENABLED=true
AGENT_GIT_SERVER_ENABLED=true
AGENT_CONTEXT_SERVER_ENABLED=true

# Debug
DEBUG=false
